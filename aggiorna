#!/bin/bash
#
# aggiorna ‚Äî Fedora (non-immutable) maintenance & update helper
# by R‚àûtGPT ‚Äî original "pipeline" interface (unrelated to Nala)
#

#== Colors (real ESC, so they work both with printf and echo) ================
RESET=$'\e[0m'
BOLD=$'\e[1m'
DIM=$'\e[38;2;96;106;128m'      # slate-grey for the rules
GREEN=$'\e[38;2;80;220;130m'
RED=$'\e[38;2;255;95;95m'
CYAN=$'\e[38;2;0;220;210m'
GOLD=$'\e[38;2;255;200;90m'

#== Global state =============================================================
steps_ok=0
steps_fail=0
SCRIPT_UPDATE='‚Äî'
FIRST_STEP=1

# Overall progress is measured in milli-packages (1 package = 1000 units), so a
# section can contribute fractional progress while the whole transaction is
# resolved up-front during planning ‚Äî the TOTAL bar denominator never rescales.
G_TOTAL_PKG=0    # total packages across every section (Cromite excluded)
G_DONE_MU=0      # completed milli-packages from already-finished sections

# Pre-resolved plan (filled by plan_phase)
DNF_UPG=0
DNF_AUTO=0
FU_REFS=()       # Flatpak refs to update
FX_REFS=()       # unused Flatpak refs to remove

# Live block bookkeeping
LIVE_DRAWN=0
LIVE_LINES=3
SPIN=('‚óú' '‚óÝ' '‚óù' '‚óû' '‚ó°' '‚óü')   # rotating arc (not braille!)

# Terminal geometry for the fixed TOTAL footer (bottom 2 reserved rows)
TERM_ROWS=24
TERM_COLS=80

#== Utilities ================================================================

# repeat a (possibly multibyte) character n times
rep() { local n=$1 ch=$2 i; for ((i=0; i<n; i++)); do printf '%s' "$ch"; done; }

# write text applying a truecolor gradient from (r1,g1,b1) to (r2,g2,b2)
grad_text() {
    local text="$1" r1=$2 g1=$3 b1=$4 r2=$5 g2=$6 b2=$7
    local len=${#text} i r g b den
    den=$(( len > 1 ? len - 1 : 1 ))
    for ((i=0; i<len; i++)); do
        r=$(( r1 + (r2 - r1) * i / den ))
        g=$(( g1 + (g2 - g1) * i / den ))
        b=$(( b1 + (b2 - b1) * i / den ))
        printf '\e[1m\e[38;2;%d;%d;%dm%s' "$r" "$g" "$b" "${text:i:1}"
    done
    printf '%s' "$RESET"
}

fmt_time() { printf '%02d:%02d' $(( $1 / 60 )) $(( $1 % 60 )); }

kb_to_human() {
    local kb=$1 sign=''
    (( kb < 0 )) && { sign='-'; kb=$(( -kb )); }
    if   (( kb >= 1048576 )); then printf '%s%d.%d GiB' "$sign" $(( kb/1048576 )) $(( (kb%1048576)*10/1048576 ))
    elif (( kb >= 1024    )); then printf '%s%d MiB' "$sign" $(( kb/1024 ))
    else                           printf '%s%d KiB' "$sign" "$kb"
    fi
}

# percentage done/total (0 when total is unknown)
pct() { local d=$1 t=$2; (( t <= 0 )) && { printf '0'; return; }; printf '%d' $(( d * 100 / t )); }

# a [‚ñà‚ñà‚ñà‚ñà‚ñà‚ñà‚ñë‚ñë‚ñë‚ñë] progress bar of the given width
draw_bar() {
    local d=$1 t=$2 w=$3 fill
    if (( t <= 0 )); then fill=0; else fill=$(( d * w / t )); fi
    (( fill > w )) && fill=$w; (( fill < 0 )) && fill=0
    printf '%s[%s%s%s%s%s]%s' \
        "$DIM" "$CYAN" "$(rep $fill '‚ñà')" "$DIM" "$(rep $(( w - fill )) '‚îÄ')" "$DIM" "$RESET"
}

# extract the package/label from a "[n/m] NAME   100% | speed | size | time" line,
# cutting exactly before the metrics field (the name may be truncated to the column,
# leaving only a single trailing space, so a double-space cut is not reliable)
clean_name() {
    local rest="$1"
    if [[ $rest =~ ^(.+[^[:space:]])[[:space:]]+[0-9]+%[[:space:]]\| ]]; then
        printf '%s' "${BASH_REMATCH[1]}"
    else
        printf '%s' "${rest%%  *}"
    fi
}

# strip the English action verb so only the package name is shown
strip_verb() {
    local s="$1" v
    for v in 'Installing ' 'Upgrading ' 'Reinstalling ' 'Downgrading ' \
             'Removing ' 'Obsoleting ' 'Cleanup ' 'Verifying ' 'Running scriptlet: '; do
        [[ $s == "$v"* ]] && { printf '%s' "${s#"$v"}"; return; }
    done
    printf '%s' "$s"
}

#== Gradient header ==========================================================
header() {
    local width
    width=$(( TERM_COLS < 56 ? TERM_COLS : 56 ))
    (( width < 24 )) && width=24
    local bar; bar=$(rep $(( width - 4 )) '‚îÅ')

    echo
    printf '  '; grad_text "$bar" 60 110 200 0 220 210; echo
    printf '   '; grad_text "U P D A T E" 70 130 230 0 220 200
    printf '    %s‚Ä¢%s  ' "$DIM" "$RESET"; grad_text "R‚àûtGPT" 0 220 200 180 90 255; echo
    printf '  '; grad_text "$bar" 0 220 210 60 110 200; echo
    echo
}

#== Fixed TOTAL footer (reserved bottom rows, outside the scroll region) ======
setup_footer() {
    TERM_ROWS=$(tput lines 2>/dev/null || echo 24)
    TERM_COLS=$(tput cols  2>/dev/null || echo 80)
    (( TERM_ROWS < 8 )) && TERM_ROWS=8
    printf '\e[1;%dr' $(( TERM_ROWS - 2 ))     # scroll region: rows 1 .. ROWS-2
    printf '\e[1;1H'                           # cursor back to the top
    draw_total_footer 0
}

teardown_footer() {
    printf '\e7'                               # save the content cursor
    printf '\e[%d;1H\e[K' $(( TERM_ROWS - 1 )) # clear the rule row
    printf '\e[%d;1H\e[K' "$TERM_ROWS"         # clear the bar row
    printf '\e[r'                              # restore full scroll region
    printf '\e8'                               # back to the content cursor
}

# redraw the pinned TOTAL bar; argument = completed milli-packages (incl. the
# in-progress section). Uses absolute positioning + save/restore so it never
# disturbs the scrolling pipeline above it.
draw_total_footer() {
    local dmu=$1 tmu=$(( G_TOTAL_PKG * 1000 ))
    local w=$(( TERM_COLS - 34 )); (( w > 40 )) && w=40; (( w < 8 )) && w=8
    printf '\e7'
    printf '\e[%d;1H%s%s%s\e[K' $(( TERM_ROWS - 1 )) "$DIM" "$(rep $(( TERM_COLS > 2 ? TERM_COLS - 2 : 1 )) '‚îÄ')" "$RESET"
    printf '\e[%d;1H' "$TERM_ROWS"
    printf '   %sTOTAL%s  %s  %s%3s%%%s   %s%d packages%s\e[K' \
        "$BOLD" "$RESET" "$(draw_bar "$dmu" "$tmu" "$w")" \
        "$BOLD" "$(pct "$dmu" "$tmu")" "$RESET" \
        "$DIM" "$G_TOTAL_PKG" "$RESET"
    printf '\e8'
}

#== Pipeline drawing =========================================================

# vertical connector between two pipeline nodes
connector() {
    if (( FIRST_STEP )); then FIRST_STEP=0; else printf '   %s‚îÉ%s\n' "$DIM" "$RESET"; fi
}

# redraw the live 3-line block (spinner node + counter + section bar);
# sd/st are the section progress as done/total of any matching scale
render_live() {
    local spin=$1 label=$2 el=$3 counter=$4 sd=$5 st=$6
    (( LIVE_DRAWN )) && printf '\e[%dA' "$LIVE_LINES"
    LIVE_DRAWN=1
    printf '\r   %s%s%s  %s   %s%s%s\e[K\n' "$CYAN" "$spin" "$RESET" "$label" "$DIM" "$el" "$RESET"
    printf '\r      %s%s%s\e[K\n' "$DIM" "$counter" "$RESET"
    printf '\r      %ssection%s %s %s%3s%%%s\e[K\n' "$DIM" "$RESET" "$(draw_bar "$sd" "$st" 22)" "$DIM" "$(pct "$sd" "$st")" "$RESET"
}

# collapse the live block into a single result node line
finish_node() {
    local sym=$1 color=$2 label=$3
    (( LIVE_DRAWN )) && printf '\e[%dA' "$LIVE_LINES"
    printf '\r   %s%s%s  %s\e[K\n' "$color" "$sym" "$RESET" "$label"
    (( LIVE_DRAWN )) && printf '\e[J'
    LIVE_DRAWN=0
}

# error box with the tail of the command log
error_box() {
    local log=$1
    printf '   %s‚îÉ%s\n' "$DIM" "$RESET"
    printf '   %s‚îó‚îÅ error detail ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ%s\n' "$RED" "$RESET"
    tail -n 8 "$log" | sed "s/^/      ${DIM}‚îÇ${RESET} /"
    printf '   %s‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ%s\n' "$RED" "$RESET"
}

#== Plain spinner step (no per-package progress: e.g. cromup) =================
run_step() {
    local label="$1"; shift
    local log; log=$(mktemp)
    connector
    "$@" >"$log" 2>&1 &
    local pid=$! i=0 start=$SECONDS
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r   %s%s%s  %s   %s%s%s\e[K' \
            "$CYAN" "${SPIN[i%6]}" "$RESET" "$label" "$DIM" "$(fmt_time $(( SECONDS - start )))" "$RESET"
        i=$(( i + 1 )); sleep 0.12
    done
    wait "$pid"; local rc=$?
    if (( rc == 0 )); then
        printf '\r   %s‚óè%s  %s\e[K\n' "$GREEN" "$RESET" "$label"
        steps_ok=$(( steps_ok + 1 ))
    else
        printf '\r   %s‚úó%s  %s%s%s\e[K\n' "$RED" "$RESET" "$RED" "$label" "$RESET"
        steps_fail=$(( steps_fail + 1 ))
        error_box "$log"
    fi
    rm -f "$log"
}

#== Planning: resolve every section up-front so the TOTAL is known ============

# count packages in a dnf transaction summary; the command is run with "n"
# piped in so dnf resolves (and refreshes), prints the summary, then aborts
dnf_plan_count() {
    printf 'n\n' | "$@" 2>/dev/null | awk '
        /^[[:space:]]*(Installing|Upgrading|Removing|Reinstalling|Downgrading|Obsoleting):[[:space:]]+[0-9]+/ {
            for (i = 1; i <= NF; i++) if ($i ~ /^[0-9]+$/) { s += $i; break }
        }
        END { print s + 0 }'
}

# list Flatpak refs needing an update (mode=update) or that are unused (mode=unused)
flatpak_refs() {
    if [[ $1 == update ]]; then
        env LC_ALL=C flatpak update --no-deploy 2>/dev/null
    else
        printf 'n\n' | env LC_ALL=C flatpak uninstall --unused 2>/dev/null
    fi | awk -F'\t' '/^[[:space:]]*[0-9]+\./ { gsub(/^[ \t]+|[ \t]+$/,"",$3); if ($3!="") print $3 }'
}

plan_phase() {
    connector
    local tmp; tmp=$(mktemp)
    (
        upg=$(dnf_plan_count  sudo env LC_ALL=C dnf upgrade --refresh)
        auto=$(dnf_plan_count sudo env LC_ALL=C dnf autoremove)
        mapfile -t fu < <(flatpak_refs update)
        mapfile -t fx < <(flatpak_refs unused)
        {
            printf 'P_UPG=%d\n'  "${upg:-0}"
            printf 'P_AUTO=%d\n' "${auto:-0}"
            printf 'FU=%s\n' "$(printf '%s\n' "${fu[@]}")"
            printf '__FUEND__\n'
            printf 'FX=%s\n' "$(printf '%s\n' "${fx[@]}")"
            printf '__FXEND__\n'
        } > "$tmp"
    ) &
    local pid=$! i=0 start=$SECONDS
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r   %s%s%s  %s   %s%s%s\e[K' \
            "$CYAN" "${SPIN[i%6]}" "$RESET" "Planning updates" "$DIM" "$(fmt_time $(( SECONDS - start )))" "$RESET"
        i=$(( i + 1 )); sleep 0.12
    done
    wait "$pid"

    # parse the plan
    DNF_UPG=$(sed -n 's/^P_UPG=//p'  "$tmp"); DNF_UPG=${DNF_UPG:-0}
    DNF_AUTO=$(sed -n 's/^P_AUTO=//p' "$tmp"); DNF_AUTO=${DNF_AUTO:-0}
    mapfile -t FU_REFS < <(sed -n '/^FU=/,/^__FUEND__$/p' "$tmp" | sed '1s/^FU=//; /^__FUEND__$/d; /^$/d')
    mapfile -t FX_REFS < <(sed -n '/^FX=/,/^__FXEND__$/p' "$tmp" | sed '1s/^FX=//; /^__FXEND__$/d; /^$/d')
    rm -f "$tmp"

    G_TOTAL_PKG=$(( DNF_UPG + DNF_AUTO + ${#FU_REFS[@]} + ${#FX_REFS[@]} ))
    draw_total_footer 0
    printf '\r   %s‚óè%s  Planning complete  %s(%d package(s) to process)%s\e[K\n' \
        "$GREEN" "$RESET" "$DIM" "$G_TOTAL_PKG" "$RESET"
}

#== DNF step with download + transaction progress ============================
# run_dnf "Label" "Install|Remove" pkgcount sudo env LC_ALL=C dnf ...
run_dnf() {
    local label="$1" p2="$2" pkg="$3"; shift 3
    local log; log=$(mktemp)
    connector

    local phase=resolve
    local dl_done=0 dl_total=0 in_done=0 in_total=0
    local counter="resolving‚Ä¶"
    local start=$SECONDS i=0 rc=-1
    local re='^\[[[:space:]]*([0-9]+)/[[:space:]]*([0-9]+)\][[:space:]]+(.*)$'
    local fd
    exec {fd}< <( { "$@"; printf '\n__RC__%d__\n' "$?"; } 2>&1 )

    render_live "${SPIN[0]}" "$label" '00:00' "$counter" 0 1
    draw_total_footer "$G_DONE_MU"

    while true; do
        if IFS= read -t 0.12 -r -u "$fd" line; then
            case "$line" in __RC__*__) rc=${line#__RC__}; rc=${rc%__}; continue;; esac
            printf '%s\n' "$line" >>"$log"
            [[ $line == "Running transaction"* ]] && phase=install
            if [[ $line =~ $re ]]; then
                local n=${BASH_REMATCH[1]} m=${BASH_REMATCH[2]} rest=${BASH_REMATCH[3]}
                local name; name=$(clean_name "$rest")
                if [[ $name != "Total" ]]; then
                    if [[ $phase == install ]]; then
                        in_total=$m; in_done=$n; counter="$p2 $n/$m: $(strip_verb "$name")"
                    else
                        dl_total=$m; dl_done=$n; counter="Download $n/$m: $name"
                    fi
                fi
            fi
        else
            (( $? > 128 )) || break
        fi
        # section completion as a per-mille fraction (download 50% + install 50%)
        local f=0
        if   (( dl_total > 0 && in_total > 0 )); then f=$(( 500 * dl_done / dl_total + 500 * in_done / in_total ))
        elif (( in_total > 0 ));                 then f=$(( 1000 * in_done / in_total ))
        elif (( dl_total > 0 ));                 then f=$(( 1000 * dl_done / dl_total ))
        fi
        render_live "${SPIN[i%6]}" "$label" "$(fmt_time $(( SECONDS - start )))" "$counter" "$f" 1000
        draw_total_footer $(( G_DONE_MU + f * pkg ))
        i=$(( i + 1 ))
    done
    exec {fd}<&-

    G_DONE_MU=$(( G_DONE_MU + pkg * 1000 ))
    draw_total_footer "$G_DONE_MU"
    if (( rc == 0 )); then
        finish_node '‚óè' "$GREEN" "$label"; steps_ok=$(( steps_ok + 1 ))
    else
        finish_node '‚úó' "$RED" "$label"; steps_fail=$(( steps_fail + 1 )); error_box "$log"
    fi
    rm -f "$log"
}

#== Flatpak section: update or remove one ref at a time ======================
# run_flatpak "Label" update|remove ref...
run_flatpak() {
    local label="$1" mode="$2"; shift 2
    local refs=("$@") N=$#
    local log; log=$(mktemp)
    connector

    local verb; [[ $mode == update ]] && verb=Update || verb=Remove

    if (( N == 0 )); then
        render_live "${SPIN[0]}" "$label" '00:00' 'nothing to do' 1 1
        draw_total_footer "$G_DONE_MU"
        finish_node '‚óè' "$GREEN" "$label"; steps_ok=$(( steps_ok + 1 )); rm -f "$log"; return
    fi

    local rc=0 start=$SECONDS i=0 idx=0 ref
    for ref in "${refs[@]}"; do
        idx=$(( idx + 1 ))
        local cur_pct=0 lrc=0 fd
        if [[ $mode == update ]]; then
            exec {fd}< <( { env LC_ALL=C flatpak update -y "$ref"; printf '\n__RC__%d__\n' "$?"; } 2>&1 )
        else
            exec {fd}< <( { env LC_ALL=C flatpak uninstall -y "$ref"; printf '\n__RC__%d__\n' "$?"; } 2>&1 )
        fi
        while true; do
            if IFS= read -t 0.12 -r -u "$fd" line; then
                case "$line" in __RC__*__) lrc=${line#__RC__}; lrc=${lrc%__}; continue;; esac
                printf '%s\n' "$line" >>"$log"
                [[ $line =~ ([0-9]+)%[^0-9]*$ ]] && cur_pct=${BASH_REMATCH[1]}
            else
                (( $? > 128 )) || break
            fi
            local sd=$(( (idx - 1) * 1000 + cur_pct * 10 ))
            render_live "${SPIN[i%6]}" "$label" "$(fmt_time $(( SECONDS - start )))" \
                "$verb $idx/$N: $ref" "$sd" "$(( N * 1000 ))"
            draw_total_footer $(( G_DONE_MU + sd ))
            i=$(( i + 1 ))
        done
        exec {fd}<&-
        (( lrc != 0 )) && rc=1
    done

    G_DONE_MU=$(( G_DONE_MU + N * 1000 ))
    draw_total_footer "$G_DONE_MU"
    if (( rc == 0 )); then
        finish_node '‚óè' "$GREEN" "$label"; steps_ok=$(( steps_ok + 1 ))
    else
        finish_node '‚úó' "$RED" "$label"; steps_fail=$(( steps_fail + 1 )); error_box "$log"
    fi
    rm -f "$log"
}

#== Report card =============================================================
card_line() {
    local label="$1" value="$2" vcolor="$3"
    local inner=46
    local left="  ${label}"
    local pad=$(( inner - ${#left} - ${#value} - 2 ))
    (( pad < 1 )) && pad=1
    printf '  %s‚îÇ%s%s%*s%s%s%s  %s‚îÇ%s\n' \
        "$CYAN" "$RESET" "$left" "$pad" '' "$vcolor" "$value" "$RESET" "$CYAN" "$RESET"
}

report_card() {
    local inner=46
    local rule; rule=$(rep "$inner" '‚îÄ')
    local title='R E P O R T'
    local tpad=$(( (inner - ${#title}) / 2 ))

    echo
    printf '  %s‚ï≠%s‚ïÆ%s\n' "$CYAN" "$rule" "$RESET"
    printf '  %s‚îÇ%s%*s%s%s%s%*s%s‚îÇ%s\n' \
        "$CYAN" "$RESET" "$tpad" '' "$GOLD$BOLD" "$title" "$RESET" \
        $(( inner - tpad - ${#title} )) '' "$CYAN" "$RESET"
    printf '  %s‚îú%s‚î§%s\n' "$CYAN" "$rule" "$RESET"

    local ok_color="$GREEN"; (( steps_fail > 0 )) && ok_color="$GOLD"
    card_line "Operations succeeded" "${steps_ok}/$(( steps_ok + steps_fail ))" "$ok_color$BOLD"
    card_line "Packages processed"   "${G_TOTAL_PKG}"                            "$BOLD"
    card_line "Time elapsed"         "$(fmt_time "$SECONDS")"                     "$BOLD"
    local freed=$(( END_AVAIL - START_AVAIL ))
    if (( freed >= 0 )); then
        card_line "Space freed"  "$(kb_to_human "$freed")"   "$GREEN$BOLD"
    else
        card_line "Space used"   "$(kb_to_human "$(( -freed ))")" "$GOLD$BOLD"
    fi
    card_line "Script update" "$SCRIPT_UPDATE"            "$BOLD"

    printf '  %s‚ï∞%s‚ïØ%s\n' "$CYAN" "$rule" "$RESET"
    echo
}

#== Cleanup: reset the scroll region, restore the cursor, stop sudo keep-alive =
cleanup() {
    printf '\e[r'                                      # reset the scroll region
    printf '\e[?25h'                                   # show the cursor again
    [ -n "${SUDO_PID:-}" ] && kill "$SUDO_PID" 2>/dev/null
}
trap cleanup EXIT INT TERM

#== START ===================================================================
clear
setup_footer
header

# Root credentials + keep-alive (steps read package-manager output through a
# pipe, so sudo must never stop to ask for the password mid-run)
printf '   %süîë Administrator authentication required...%s\n\n' "$GOLD" "$RESET"
if ! sudo -v; then
    printf '   %s‚úó Authentication failed. Exiting.%s\n' "$RED" "$RESET"
    exit 1
fi
( while true; do sudo -n true; sleep 50; kill -0 "$$" 2>/dev/null || exit; done ) 2>/dev/null &
SUDO_PID=$!

printf '\e[?25l'                                        # hide the cursor
START_AVAIL=$(df --output=avail / | tail -1 | tr -d ' ')

# Resolve everything first (one metadata refresh), so the TOTAL bar is exact.
plan_phase

# The upgrade reuses the metadata just refreshed during planning (no --refresh).
run_dnf      "System upgrade (DNF)"        "Install" "$DNF_UPG"  sudo env LC_ALL=C dnf upgrade -y
run_dnf      "Removing orphaned packages"  "Remove"  "$DNF_AUTO" sudo env LC_ALL=C dnf autoremove -y
run_flatpak  "Updating Flatpaks"           update "${FU_REFS[@]}"
run_flatpak  "Removing unused Flatpaks"    remove "${FX_REFS[@]}"

# Optional hook: cromup (Cromite) ‚Äî excluded from the overall progress bar
if [ -x /usr/local/bin/cromup ]; then
    run_step "Updating Cromite (cromup)" cromup
fi

END_AVAIL=$(df --output=avail / | tail -1 | tr -d ' ')
teardown_footer

#== Script self-update ======================================================
if curl -fsSL https://raw.githubusercontent.com/RootGPT-YouTube/FedoraUP/main/aggiorna -o /tmp/aggiorna.tmp 2>/dev/null; then
    if ! cmp -s /tmp/aggiorna.tmp /usr/local/bin/aggiorna 2>/dev/null; then
        if sudo mv /tmp/aggiorna.tmp /usr/local/bin/aggiorna && sudo chmod a+x /usr/local/bin/aggiorna; then
            SCRIPT_UPDATE='updated ‚úì'
        else
            SCRIPT_UPDATE='error ‚úó'
        fi
    else
        SCRIPT_UPDATE='already up to date'
        rm -f /tmp/aggiorna.tmp
    fi
else
    rm -f /tmp/aggiorna.tmp
    SCRIPT_UPDATE='not checked'
fi

#== Report + exit ===========================================================
report_card
printf '\e[?25h'
read -r -p "$(printf '   %s‚Üµ Press ENTER to close%s' "$DIM" "$RESET")"
clear
# == End of script ==
